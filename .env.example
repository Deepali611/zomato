# Hugging Face dataset
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Groq LLM (primary provider)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# Optional alias for provider key (used when LLM_PROVIDER=groq)
# LLM_API_KEY=

# Recommendation pipeline
MAX_CANDIDATES=20
TOP_K=5
FILTER_RELAX_ON_EMPTY=true
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LOG_LEVEL=INFO

# Budget tier thresholds (INR cost for two)
# LOW_MAX=400
# HIGH_MAX=800
